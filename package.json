{
  "name": "plural-space-desktop",
  "version": "1.5.0",
  "description": "Plural Star — Desktop",
  "author": {
    "name": "The Hanyou System",
    "email": "The1Hanyou@gmail.com"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n vite,electron \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:pack": "npm run build && electron-builder --dir",
    "postinstall": "node scripts/fix-bin-permissions.js"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "i18next": "^26.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "lucide-react": "^1.16.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wait-on": "^9.0.1"
  },
  "overrides": {
    "glob": "^11.0.0",
    "rimraf": "^6.0.0",
    "inflight": "npm:inflight-lru@^1.0.0"
  },
  "build": {
    "appId": "com.pluralspace.desktop",
    "productName": "Plural Star",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "build/tray.png"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.lifestyle",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "icon": "build/icons"
    }
  }
}
